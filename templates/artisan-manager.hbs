                                    <option value="optional">Opzionali: non bloccano, danno bonus solo se competente</option>
                                    <option value="required">Obbligatori: almeno uno deve essere posseduto</option>
                                </select>
                                <small>Se obbligatori, il Dissassemblare parte solo se il PG possiede almeno uno strumento della lista.</small>
                            </div>

                            <div class="artisan-inspector__field artisan-toggle-field">
                                <label>Rottura strumenti</label>
                                <label class="artisan-checkbox-line">
                                    <input type="checkbox" data-artisan-disassembly-field="toolCriticalDamage" data-profile-id="{{selectedDisassemblyProfile.id}}" {{#if selectedDisassemblyProfile.toolCriticalDamage}}checked{{/if}}>
                                    <span>Con 1 naturale lo strumento può rompersi</span>
                                </label>
                                <small>Attivalo solo per dissassemblaggi complessi o rischiosi.</small>
                            </div>
                        </div>

                        <section class="artisan-harvest-panel artisan-disassembly-panel" data-artisan-disassembly-source-drop-zone data-profile-id="{{selectedDisassemblyProfile.id}}">
                            <header class="artisan-component-panel__header">
                                <h3>Oggetto da dissassemblare</h3>
                                <span>Trascina qui la risorsa sorgente dal compendio o dal mondo</span>
                            </header>

                            <div class="artisan-component-row {{#unless selectedDisassemblyProfile.sourceFound}}is-missing{{/unless}}">
                                <img src="{{selectedDisassemblyProfile.sourceImg}}" alt="{{selectedDisassemblyProfile.sourceName}}">
                                <div class="artisan-component-row__main">
                                    <strong>{{#if selectedDisassemblyProfile.sourceName}}{{selectedDisassemblyProfile.sourceName}}{{else}}Nessuna sorgente impostata{{/if}}</strong>
                                    <code>{{selectedDisassemblyProfile.sourceUuid}}</code>
                                </div>
                                <span class="artisan-component-row__quantity-static">Consuma {{selectedDisassemblyProfile.sourceQuantity}}</span>
                            </div>
                        </section>

                        <section class="artisan-harvest-panel artisan-disassembly-panel" data-artisan-disassembly-drop-zone data-profile-id="{{selectedDisassemblyProfile.id}}" data-collection="resources">
                            <header class="artisan-component-panel__header">
                                <h3>Materiali ottenibili</h3>
                                <span>Trascina qui carne, pelle, ossa, componenti o altri materiali dal compendio</span>
                            </header>

                            <div class="artisan-component-add artisan-harvest-resource-add">
                                <input type="text" placeholder="UUID materiale" data-artisan-disassembly-component-uuid>
                                <select title="Rarità di ritrovamento" data-artisan-disassembly-component-rarity>
                                    <option value="common">{{localize 'ARTISAN.Common'}}</option>
                                    <option value="uncommon">{{localize 'ARTISAN.Uncommon'}}</option>
                                    <option value="rare">{{localize 'ARTISAN.Rare'}}</option>
                                    <option value="veryRare">{{localize 'ARTISAN.VeryRare'}}</option>
                                    <option value="legendary">{{localize 'ARTISAN.Legendary'}}</option>
                                </select>
                                <input type="number" min="0.1" step="0.1" title="Peso/probabilità manuale: se vuoto usa la rarità" placeholder="Probabilità" data-artisan-disassembly-component-weight>
                                <input type="number" min="1" step="1" value="1" title="Quantità minima" placeholder="Min" data-artisan-disassembly-component-min-quantity>
                                <input type="number" min="1" step="1" value="1" title="Quantità massima" placeholder="Max" data-artisan-disassembly-component-max-quantity>
                                <button type="button" class="artisan-small-button" data-artisan-disassembly-add-component data-profile-id="{{selectedDisassemblyProfile.id}}" data-collection="resources">
                                    <i class="fa-solid fa-plus"></i>
                                    {{localize 'ARTISAN.Add'}}
                                </button>
                            </div>

                            {{#if selectedDisassemblyProfile.resources.length}}
                                <div class="artisan-component-list">
                                    {{#each selectedDisassemblyProfile.resources}}
                                        <div class="artisan-component-row artisan-harvest-row artisan-harvest-resource-row {{#unless found}}is-missing{{/unless}}">
                                            <img src="{{img}}" alt="{{name}}">
                                            <div class="artisan-component-row__main">
                                                <strong>{{name}}</strong>
                                                <code>{{uuid}}</code>
                                            </div>

                                            <label class="artisan-harvest-edit-field" title="Rarità di ritrovamento">
                                                <span>{{localize 'ARTISAN.Rarity'}}</span>
                                                <select
                                                    data-artisan-disassembly-rarity-select
                                                    data-current-rarity="{{rarity}}"
                                                    data-artisan-disassembly-component-field="rarity"
                                                    data-profile-id="{{profileId}}"
                                                    data-collection="{{collection}}"
                                                    data-index="{{index}}"
                                                >
                                                    <option value="common">{{localize 'ARTISAN.Common'}}</option>
                                                    <option value="uncommon">{{localize 'ARTISAN.Uncommon'}}</option>
                                                    <option value="rare">{{localize 'ARTISAN.Rare'}}</option>
                                                    <option value="veryRare">{{localize 'ARTISAN.VeryRare'}}</option>
                                                    <option value="legendary">{{localize 'ARTISAN.Legendary'}}</option>
                                                </select>
                                            </label>

                                            <label class="artisan-harvest-edit-field" title="Peso/probabilità manuale. La rarità aggiorna questo valore automaticamente.">
                                                <span>Prob.</span>
                                                <input type="number" min="0.1" step="0.1" value="{{weight}}" data-artisan-disassembly-component-field="weight" data-profile-id="{{profileId}}" data-collection="{{collection}}" data-index="{{index}}">
                                            </label>

                                            <label class="artisan-harvest-edit-field" title="Quantità minima">
                                                <span>Min</span>
                                                <input type="number" min="1" step="1" value="{{minQuantity}}" data-artisan-disassembly-component-field="minQuantity" data-profile-id="{{profileId}}" data-collection="{{collection}}" data-index="{{index}}">
                                            </label>

                                            <label class="artisan-harvest-edit-field" title="Quantità massima">
                                                <span>Max</span>
                                                <input type="number" min="1" step="1" value="{{maxQuantity}}" data-artisan-disassembly-component-field="maxQuantity" data-profile-id="{{profileId}}" data-collection="{{collection}}" data-index="{{index}}">
                                            </label>

                                            <button type="button" class="artisan-icon-button" data-artisan-disassembly-remove-component data-profile-id="{{profileId}}" data-collection="{{collection}}" data-index="{{index}}" title="Rimuovi">
                                                <i class="fa-solid fa-trash"></i>
                                            </button>
                                        </div>
                                    {{/each}}
                                </div>
                            {{else}}
                                <p class="artisan-component-panel__empty">Nessun materiale configurato.</p>
                            {{/if}}
                        </section>

                        <section class="artisan-harvest-panel artisan-disassembly-panel" data-artisan-disassembly-drop-zone data-profile-id="{{selectedDisassemblyProfile.id}}" data-collection="tools">
                            <header class="artisan-component-panel__header">
                                <h3>Strumenti bonus alla prova</h3>
                                <span>Se il PG possiede lo strumento ed è competente, aggiunge il bonus competenza alla prova.</span>
                            </header>

                            <div class="artisan-component-add">
                                <input type="text" placeholder="UUID strumento" data-artisan-disassembly-component-uuid>
                                <span class="artisan-inline-note">Bonus = competenza PG</span>
                                <button type="button" class="artisan-small-button" data-artisan-disassembly-add-component data-profile-id="{{selectedDisassemblyProfile.id}}" data-collection="tools">
                                    <i class="fa-solid fa-plus"></i>
                                    {{localize 'ARTISAN.Add'}}
                                </button>
                            </div>

                            {{#if selectedDisassemblyProfile.tools.length}}
                                <div class="artisan-component-list">
                                    {{#each selectedDisassemblyProfile.tools}}
                                        <div class="artisan-component-row artisan-harvest-row {{#unless found}}is-missing{{/unless}}">
                                            <img src="{{img}}" alt="{{name}}">
                                            <div class="artisan-component-row__main">
                                                <strong>{{name}}</strong>
                                                <code>{{uuid}}</code>
                                            </div>
                                            <span class="artisan-component-row__quantity-static">{{quantityLabel}}</span>
                                            <button type="button" class="artisan-icon-button" data-artisan-disassembly-remove-component data-profile-id="{{profileId}}" data-collection="{{collection}}" data-index="{{index}}" title="Rimuovi">
                                                <i class="fa-solid fa-trash"></i>
                                            </button>
                                        </div>
                                    {{/each}}
                                </div>
                            {{else}}
                                <p class="artisan-component-panel__empty">Nessuno strumento configurato.</p>
                            {{/if}}
                        </section>

                        <section class="artisan-inspector__summary">
                            <div><strong>{{selectedDisassemblyProfile.resourceCount}}</strong><span>Materiali</span></div>
                            <div><strong>{{selectedDisassemblyProfile.totalResourceWeight}}</strong><span>Peso totale</span></div>
                            <div><strong>{{selectedDisassemblyProfile.maxResources}}</strong><span>Max diversi</span></div>
                            <div><strong>{{selectedDisassemblyProfile.dc}}</strong><span>{{localize 'ARTISAN.DC'}}</span></div>
                        </section>

                    {{else}}

                        <section class="artisan-manager__empty">
                            <i class="fa-solid fa-screwdriver-wrench"></i>
                            <h3>Nessuna lista Dissassemblare</h3>
                            <p>Crea una lista per trasformare una risorsa sorgente in materiali casuali.</p>
                        </section>

                    {{/if}}
                </main>

            </section>

        {{/if}}


        {{#if isProfessionsSection}}

            <header class="artisan-manager__toolbar">
                <h3>{{localize 'ARTISAN.ActorProfessions'}}</h3>

                <div class="artisan-toolbar-actions">
                    <button type="button" class="artisan-button" data-artisan-refresh-actor-professions>
                        <i class="fa-solid fa-rotate"></i>
                        {{localize 'ARTISAN.Refresh'}}
                    </button>
                </div>
            </header>

            {{#if selectedActorName}}

                <section class="artisan-inspector artisan-professions-panel">

                    <header class="artisan-inspector__header">
                        <div class="artisan-inspector__header-main">
                            <div>
                                <h2>{{selectedActorName}}</h2>
                                <p>{{localize 'ARTISAN.SavedOnActorFlags'}}</p>
                                <p class="artisan-inline-note">{{localize 'ARTISAN.XpRecalculatesLevel'}}</p>
                            </div>
                        </div>
                    </header>

                    <section class="artisan-profession-summary">
                        <div class="artisan-profession-summary__card">
                            <strong>{{selectedActorProfessionSummary.trainedCount}}</strong>
                            <span>{{localize 'ARTISAN.TrainedProfessions'}}</span>
                        </div>
                        <div class="artisan-profession-summary__card">
                            <strong>{{selectedActorProfessionSummary.totalXp}}</strong>
                            <span>{{localize 'ARTISAN.TotalXp'}}</span>
                        </div>
                        <div class="artisan-profession-summary__card">
                            <strong>{{selectedActorProfessionSummary.highestLabel}} {{selectedActorProfessionSummary.highestLevel}}</strong>
                            <span>{{localize 'ARTISAN.BestProfession'}}</span>
                        </div>
                        <div class="artisan-profession-summary__card">
                            <strong>{{selectedActorProfessionSummary.nextXpToLevel}}</strong>
                            <span>{{localize 'ARTISAN.XpToNextLevel'}}: {{selectedActorProfessionSummary.nextLabel}}</span>
                        </div>
                    </section>

                    <div class="artisan-profession-list">
                        {{#each selectedActorProfessions}}
                            <article class="artisan-profession-card">
                                <div class="artisan-profession-card__main">
                                    <h3>{{label}}</h3>
                                    <p>{{localize 'ARTISAN.Gathering'}} {{gatheringMultiplierLabel}} · {{localize 'ARTISAN.Crafting'}} {{craftingMultiplierLabel}}</p>
                                </div>

                                <label>
                                    <span>{{localize 'ARTISAN.Level'}}</span>
                                    <input
                                        type="number"
                                        min="0"
                                        max="{{maxLevel}}"
                                        step="1"
                                        value="{{level}}"
                                        data-artisan-actor-profession-field
                                        data-actor-profession-field="level"
                                        data-profession-id="{{id}}"
                                    >
                                </label>

                                <label>
                                    <span>XP</span>
                                    <small>{{localize 'ARTISAN.XpLevelUpdates'}}</small>
                                    <input
                                        type="number"
                                        min="0"
                                        step="1"
                                        value="{{xp}}"
                                        data-artisan-actor-profession-field
                                        data-actor-profession-field="xp"
                                        data-profession-id="{{id}}"
                                    >
                                </label>

                                <div class="artisan-profession-progress">
                                    <div class="artisan-profession-progress__bar">
                                        <span style="width: {{progressPercent}}%;"></span>
                                    </div>
                                    {{#if xpForNextLevel}}
                                        <small>{{xp}} / {{xpForNextLevel}} XP · {{localize 'ARTISAN.Missing'}} {{xpToNextLevel}} XP</small>
                                    {{else}}
                                        <small>{{localize 'ARTISAN.MaxLevelReached'}}</small>
                                    {{/if}}
                                </div>

                                <div class="artisan-profession-quick-actions">
                                    <button type="button" class="artisan-small-button" data-artisan-profession-xp-action data-action="add10" data-profession-id="{{id}}">+10 XP</button>
                                    <button type="button" class="artisan-small-button" data-artisan-profession-xp-action data-action="add50" data-profession-id="{{id}}">+50 XP</button>
                                    <button type="button" class="artisan-small-button" data-artisan-profession-xp-action data-action="next" data-profession-id="{{id}}">{{localize 'ARTISAN.NextLevel'}}</button>
                                    <button type="button" class="artisan-small-button artisan-danger-button" data-artisan-profession-xp-action data-action="reset" data-profession-id="{{id}}">Reset XP</button>
                                </div>
                            </article>
                        {{/each}}
                    </div>

                </section>

            {{else}}

                <section class="artisan-manager__empty">
                    <i class="fa-solid fa-user-gear"></i>
                    <h3>{{localize 'ARTISAN.NoActorSelected'}}</h3>
                    <p>{{localize 'ARTISAN.SelectTokenForProfessions'}}</p>
                </section>

            {{/if}}

        {{/if}}


        {{#if isActivitySection}}

            <header class="artisan-manager__toolbar">
                <h3>{{localize 'ARTISAN.ActivityLog'}}</h3>

                <div class="artisan-toolbar-actions">
                    <button type="button" class="artisan-button" data-artisan-refresh-activity>
                        <i class="fa-solid fa-rotate"></i>
                        {{localize 'ARTISAN.Refresh'}}
                    </button>

                    <button type="button" class="artisan-button" data-artisan-export-activity>
                        <i class="fa-solid fa-file-export"></i>
                        {{localize 'ARTISAN.ExportLog'}}
                    </button>

                    <button type="button" class="artisan-button artisan-button--danger" data-artisan-clear-activity>
                        <i class="fa-solid fa-trash"></i>
                        {{localize 'ARTISAN.ClearLog'}}
                    </button>
                </div>
            </header>

            {{#if activityLog.length}}
                <section class="artisan-activity-log">
                    {{#each activityLog}}
                        <article class="artisan-activity-entry artisan-activity-entry--{{type}}">
                            <div class="artisan-activity-entry__icon">
                                <i class="{{icon}}"></i>
                            </div>

                            <div class="artisan-activity-entry__body">
                                <header>
                                    <strong>{{title}}</strong>
                                    <span>{{timeLabel}}</span>
                                </header>
                                <p>{{message}}</p>
                                {{#if actorName}}<small>{{localize 'ARTISAN.ActorShort'}}: {{actorName}}</small>{{/if}}
                            </div>
                        </article>
                    {{/each}}
                </section>
            {{else}}
                <section class="artisan-manager__empty">
                    <i class="fa-solid fa-clock-rotate-left"></i>
                    <h3>{{localize 'ARTISAN.NoActivityLogged'}}</h3>
                    <p>{{localize 'ARTISAN.ActivityEmptyText'}}</p>
                </section>
            {{/if}}

        {{/if}}


        {{#if isPresetsSection}}

            <header class="artisan-manager__toolbar">
                <h3>{{localize 'ARTISAN.PresetPackages'}}</h3>

                <div class="artisan-toolbar-actions">
                    <button type="button" class="artisan-button" data-artisan-install-all-preset-packages>
                        <i class="fa-solid fa-boxes-stacked"></i>
                        {{localize 'ARTISAN.InstallAll'}}
                    </button>
                </div>
            </header>

            <section class="artisan-preset-panel">
                <div class="artisan-preset-panel__intro">
                    <h2>{{localize 'ARTISAN.BasePresetPackages'}}</h2>
                    <p>{{localize 'ARTISAN.PresetIntro'}}</p>
                </div>

                <div class="artisan-preset-grid">
                    {{#each presetPackages}}
                        <article class="artisan-preset-card">
                            <div class="artisan-preset-card__icon">
                                <i class="{{icon}}"></i>
                            </div>

                            <div class="artisan-preset-card__body">
                                <header>
                                    <h3>{{title}}</h3>
                                    <span>{{entries}} elementi</span>
                                </header>

                                <strong>{{subtitle}}</strong>
                                <p>{{description}}</p>

                                <button
                                    type="button"
                                    class="artisan-button"
                                    data-artisan-install-preset-package
                                    data-preset-id="{{id}}"
                                >
                                    <i class="fa-solid fa-download"></i>
                                    {{localize 'ARTISAN.InstallPackage'}}
                                </button>
                            </div>
                        </article>
                    {{/each}}
                </div>
            </section>

        {{/if}}


        {{#if isHelpSection}}

            <header class="artisan-manager__toolbar artisan-toolbar--hero">
                <div>
                    <h3>{{localize 'ARTISAN.Help'}}</h3>
                    <p>{{localize 'ARTISAN.HelpSubtitle'}}</p>
                </div>
            </header>

            <section class="artisan-help">
                <article class="artisan-help-hero">
                    <div class="artisan-help-hero__icon">
                        <i class="fa-solid fa-hammer"></i>
                    </div>
                    <div>
                        <h2>{{localize 'ARTISAN.HelpHeroTitle'}}</h2>
                        <p>{{localize 'ARTISAN.HelpHeroText'}}</p>
                    </div>
                </article>

                <div class="artisan-help-grid">
                    <article class="artisan-help-card">
                        <i class="fa-solid fa-book"></i>
                        <h3>{{localize 'ARTISAN.HelpCraftingTitle'}}</h3>
                        <p>{{localize 'ARTISAN.HelpCraftingText'}}</p>
                    </article>

                    <article class="artisan-help-card">
                        <i class="fa-solid fa-leaf"></i>
                        <h3>{{localize 'ARTISAN.HelpForagingTitle'}}</h3>
                        <p>{{localize 'ARTISAN.HelpForagingText'}}</p>
                    </article>

                    <article class="artisan-help-card">
                        <i class="fa-solid fa-paw"></i>
                        <h3>{{localize 'ARTISAN.HelpHarvestTitle'}}</h3>
                        <p>{{localize 'ARTISAN.HelpHarvestText'}}</p>
                    </article>

                    <article class="artisan-help-card">
                        <i class="fa-solid fa-user-gear"></i>
                        <h3>{{localize 'ARTISAN.HelpProfessionsTitle'}}</h3>
                        <p>{{localize 'ARTISAN.HelpProfessionsText'}}</p>
                    </article>
                </div>

                <section class="artisan-help-steps">
                    <h3>{{localize 'ARTISAN.HelpWorkflowTitle'}}</h3>

                    <ol>
                        <li>{{localize 'ARTISAN.HelpStep1'}}</li>
                        <li>{{localize 'ARTISAN.HelpStep2'}}</li>
                        <li>{{localize 'ARTISAN.HelpStep3'}}</li>
                        <li>{{localize 'ARTISAN.HelpStep4'}}</li>
                    </ol>
                </section>

                <section class="artisan-help-notes">
                    <article>
                        <strong>{{localize 'ARTISAN.HelpTipTitle'}}</strong>
                        <p>{{localize 'ARTISAN.HelpTipText'}}</p>
                    </article>

                    <article>
                        <strong>{{localize 'ARTISAN.HelpDataTitle'}}</strong>
                        <p>{{localize 'ARTISAN.HelpDataText'}}</p>
                    </article>
                </section>
            </section>

        {{/if}}


        {{#if isSettingsSection}}

            <header class="artisan-manager__toolbar">
                <h3>{{localize 'ARTISAN.ModuleSettings'}}</h3>

                <div class="artisan-toolbar-actions">
                    <button type="button" class="artisan-button" data-artisan-reset-settings>
                        <i class="fa-solid fa-rotate-left"></i>
                        {{localize 'ARTISAN.RestoreDefaults'}}
                    </button>
                </div>
            </header>

            <section class="artisan-inspector artisan-settings-panel">
                <header class="artisan-inspector__header">
                    <div class="artisan-inspector__header-main">
                        <div>
                            <h2>{{localize 'ARTISAN.ArtisanSettings'}}</h2>
                            <p>{{localize 'ARTISAN.SettingsSavedWorld'}}</p>
                            <p class="artisan-inline-note">{{localize 'ARTISAN.SettingsIntro'}}</p>
                        </div>
                    </div>
                </header>

                <div class="artisan-settings-list">
                    {{#each artisanSettings}}
                        <label class="artisan-setting-row">
                            <input
                                type="checkbox"
                                {{#if checked}}checked{{/if}}
                                data-artisan-setting-field
                                data-artisan-setting-key="{{key}}"
                            >
                            <span class="artisan-setting-row__content">
                                <strong>{{label}}</strong>
                                <small>{{description}}</small>
                            </span>
                        </label>
                    {{/each}}
                </div>
            </section>

        {{/if}}



    </main>

</div>