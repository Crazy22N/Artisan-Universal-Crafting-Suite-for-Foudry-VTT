<div class="artisan-manager__layout">

    <aside class="artisan-manager__sidebar">

        <div class="artisan-manager__brand">
            <h2>{{title}}</h2>
            <p>{{subtitle}}</p>
        </div>

        <nav class="artisan-explorer">
            {{#each explorer}}
                <section class="artisan-explorer__section {{#if selected}}is-selected{{/if}} {{#if collapsed}}is-collapsed{{/if}}" data-section="{{id}}">

                    <button
                        type="button"
                        class="artisan-explorer__section-header artisan-explorer__section-button {{#if selected}}is-selected{{/if}}"
                        data-artisan-toggle-explorer-section
                        data-section-id="{{id}}"
                        aria-expanded="{{#if expanded}}true{{else}}false{{/if}}"
                    >
                        <span class="artisan-explorer__section-title">
                            <i class="{{icon}}"></i>
                            {{label}}
                        </span>

                        <span class="artisan-explorer__section-meta">
                            <span class="artisan-explorer__count">{{count}}</span>
                            <i class="fa-solid fa-chevron-down artisan-explorer__chevron"></i>
                        </span>
                    </button>

                    {{#if expanded}}
                        <div class="artisan-explorer__items">
                            {{#if items.length}}
                                {{#each items}}
                                    {{#if (eq kind "recipe")}}
                                        <button
                                            type="button"
                                            class="artisan-explorer__item {{#if selected}}is-selected{{/if}} {{recipeStatusClass}}"
                                            title="{{recipeStatusTitle}}"
                                            data-artisan-select-recipe
                                            data-recipe-id="{{id}}"
                                        >
                                            <span class="artisan-explorer__item-main">
                                                {{#if icon}}<i class="{{icon}}"></i>{{else}}<i class="fa-solid fa-flask"></i>{{/if}}
                                                <span>{{label}}</span>
                                            </span>
                                            {{#if recipeStatusLabel}}
                                                <span class="artisan-recipe-status-badge {{recipeStatusClass}}">
                                                    <i class="{{recipeStatusIcon}}"></i>
                                                    {{recipeStatusLabel}}
                                                </span>
                                            {{/if}}
                                        </button>
                                    {{/if}}

                                    {{#if (eq kind "foraging")}}
                                        <button
                                            type="button"
                                            class="artisan-explorer__item {{#if selected}}is-selected{{/if}}"
                                            data-artisan-select-foraging-profile
                                            data-profile-id="{{id}}"
                                        >
                                            <span class="artisan-explorer__item-main">
                                                {{#if icon}}<i class="{{icon}}"></i>{{else}}<i class="fa-solid fa-leaf"></i>{{/if}}
                                                <span>{{label}}</span>
                                            </span>
                                        </button>
                                    {{/if}}

                                    {{#if (eq kind "harvest")}}
                                        <button
                                            type="button"
                                            class="artisan-explorer__item {{#if selected}}is-selected{{/if}}"
                                            data-artisan-select-harvest-profile
                                            data-profile-id="{{id}}"
                                        >
                                            <span class="artisan-explorer__item-main">
                                                {{#if icon}}<i class="{{icon}}"></i>{{else}}<i class="fa-solid fa-paw"></i>{{/if}}
                                                <span>{{label}}</span>
                                            </span>
                                        </button>
                                    {{/if}}

                                    {{#if (eq kind "disassembly")}}
                                        <button
                                            type="button"
                                            class="artisan-explorer__item {{#if selected}}is-selected{{/if}}"
                                            data-artisan-select-disassembly-profile
                                            data-profile-id="{{id}}"
                                        >
                                            <span class="artisan-explorer__item-main">
                                                {{#if icon}}<i class="{{icon}}"></i>{{else}}<i class="fa-solid fa-screwdriver-wrench"></i>{{/if}}
                                                <span>{{label}}</span>
                                            </span>
                                        </button>
                                    {{/if}}

                                    {{#if (eq kind "section")}}
                                        <button
                                            type="button"
                                            class="artisan-explorer__item {{#if selected}}is-selected{{/if}}"
                                            data-artisan-select-section
                                            data-section-id="{{id}}"
                                        >
                                            <span class="artisan-explorer__item-main">
                                                {{#if icon}}<i class="{{icon}}"></i>{{/if}}
                                                <span>{{label}}</span>
                                            </span>
                                        </button>
                                    {{/if}}
                                {{/each}}
                            {{else}}
                                <button
                                    type="button"
                                    class="artisan-explorer__item artisan-explorer__item--empty"
                                    data-artisan-select-section
                                    data-section-id="{{id}}"
                                >
                                    <span class="artisan-explorer__item-main">
                                        <i class="fa-solid fa-folder-open"></i>
                                        <span>{{localize 'ARTISAN.NoElements'}}</span>
                                    </span>
                                </button>
                            {{/if}}
                        </div>
                    {{/if}}

                </section>
            {{/each}}
        </nav>

    </aside>

    <main class="artisan-manager__content">

        {{#if isRecipesSection}}

            <header class="artisan-manager__toolbar">
                <h3>{{localize 'ARTISAN.Recipes'}}</h3>

                <div class="artisan-toolbar-actions">
                    <button type="button" class="artisan-button" data-artisan-new-recipe>
                        <i class="fa-solid fa-plus"></i>
                        {{localize 'ARTISAN.NewRecipe'}}
                    </button>

                    <button type="button" class="artisan-button" data-artisan-import-recipes>
                        <i class="fa-solid fa-file-import"></i>
                        {{localize 'ARTISAN.ImportRecipes'}}
                    </button>

                    <button type="button" class="artisan-button" data-artisan-export-all-recipes>
                        <i class="fa-solid fa-file-export"></i>
                        {{localize 'ARTISAN.ExportAll'}}
                    </button>

                    <button type="button" class="artisan-button" data-artisan-export-backup>
                        <i class="fa-solid fa-download"></i>
                        {{localize 'ARTISAN.BackupArtisan'}}
                    </button>

                    <button type="button" class="artisan-button" data-artisan-import-backup>
                        <i class="fa-solid fa-upload"></i>
                        {{localize 'ARTISAN.RestoreBackup'}}
                    </button>
                </div>

                <input
                    type="file"
                    accept="application/json,.json"
                    class="artisan-hidden-file-input"
                    data-artisan-import-recipes-file
                >

                <input
                    type="file"
                    accept="application/json,.json"
                    class="artisan-hidden-file-input"
                    data-artisan-import-backup-file
                >
            </header>

            <section class="artisan-filter-panel">
                <div class="artisan-filter-panel__header">
                    <strong>{{localize 'ARTISAN.RecipeSearchFilters'}}</strong>
                    <span>{{recipeCountFiltered}} / {{recipeCountTotal}}</span>
                </div>

                <div class="artisan-filter-panel__grid">
                    <label>
                        <span>{{localize 'ARTISAN.NameCategory'}}</span>
                        <input
                            type="search"
                            value="{{recipeFilters.search}}"
                            placeholder="{{localize 'ARTISAN.SearchRecipePlaceholder'}}"
                            data-artisan-recipe-filter
                            data-filter="search"
                        >
                    </label>

                    <label>
                        <span>{{localize 'ARTISAN.ProfessionLabel'}}</span>
                        <select data-artisan-recipe-filter data-filter="profession">
                            <option value="all">{{localize 'ARTISAN.AllF'}}</option>
                            {{#each recipeFilterProfessionOptions}}
                                <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                            {{/each}}
                        </select>
                    </label>

                    <label>
                        <span>{{localize 'ARTISAN.Category'}}</span>
                        <select data-artisan-recipe-filter data-filter="category">
                            <option value="all">{{localize 'ARTISAN.AllF'}}</option>
                            {{#each recipeFilterCategoryOptions}}
                                <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                            {{/each}}
                        </select>
                    </label>

                    <label>
                        <span>{{localize 'ARTISAN.RequiredLevel'}}</span>
                        <select data-artisan-recipe-filter data-filter="level">
                            <option value="all">{{localize 'ARTISAN.AllM'}}</option>
                            {{#each recipeFilterLevelOptions}}
                                <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                            {{/each}}
                        </select>
                    </label>

                    <button type="button" class="artisan-small-button" data-artisan-reset-recipe-filters>
                        <i class="fa-solid fa-filter-circle-xmark"></i>
                        {{localize 'ARTISAN.ClearFilters'}}
                    </button>
                </div>
            </section>

            {{#if selectedRecipe}}

                <section class="artisan-inspector">

                    <header class="artisan-inspector__header">

                        <div class="artisan-inspector__header-main">
                            <img src="{{selectedRecipe.img}}" alt="{{selectedRecipe.name}}">
                            <div>
                                <h2>{{selectedRecipe.name}}</h2>
                                <p>{{selectedRecipe.uuid}}</p>
                            </div>
                        </div>

                        <div class="artisan-inspector__header-actions">
                            <button
                                type="button"
                                class="artisan-small-button {{#if selectedRecipe.recipeLocked}}is-disabled{{/if}}"
                                {{#if selectedRecipe.recipeLocked}}disabled{{/if}}
                                data-artisan-roll-crafting
                                data-recipe-id="{{selectedRecipe.id}}"
                            >
                                <i class="fa-solid fa-dice-d20"></i>
                                {{localize 'ARTISAN.RunCrafting'}}
                            </button>

                            <button
                                type="button"
                                class="artisan-small-button"
                                data-artisan-preview-crafting
                                data-recipe-id="{{selectedRecipe.id}}"
                            >
                                <i class="fa-solid fa-eye"></i>
                                {{localize 'ARTISAN.Preview'}}
                            </button>

                            <button
                                type="button"
                                class="artisan-small-button"
                                data-artisan-validate-recipe
                                data-recipe-id="{{selectedRecipe.id}}"
                            >
                                <i class="fa-solid fa-check"></i>
                                {{localize 'ARTISAN.Verify'}}
                            </button>

                            <button
                                type="button"
                                class="artisan-small-button"
                                data-artisan-export-recipe
                                data-recipe-id="{{selectedRecipe.id}}"
                            >
                                <i class="fa-solid fa-file-export"></i>
                                {{localize 'ARTISAN.ExportRecipe'}}
                            </button>

                            <button
                                type="button"
                                class="artisan-small-button"
                                data-artisan-duplicate-recipe
                                data-recipe-id="{{selectedRecipe.id}}"
                            >
                                <i class="fa-solid fa-copy"></i>
                                {{localize 'ARTISAN.DuplicateRecipe'}}
                            </button>
                        </div>

                    </header>

                    <section class="artisan-recipe-requirement-card {{selectedRecipe.recipeStatusClass}}">
                        <div>
                            <strong>{{localize 'ARTISAN.SelectedActorAvailability'}}</strong>
                            <p>{{selectedRecipe.recipeStatusTitle}}</p>
                        </div>
                        <span class="artisan-recipe-status-badge {{selectedRecipe.recipeStatusClass}}">
                            <i class="{{selectedRecipe.recipeStatusIcon}}"></i>
                            {{selectedRecipe.recipeStatusLabel}}
                        </span>
                    </section>

                    <div class="artisan-inspector__form">

                        <div class="artisan-inspector__field">
                            <label>{{localize 'ARTISAN.RecipeName'}}</label>
                            <input
                                type="text"
                                value="{{selectedRecipe.name}}"
                                data-artisan-field="name"
                                data-recipe-id="{{selectedRecipe.id}}"
                            >
                        </div>

                        <div class="artisan-inspector__field">
                            <label>{{localize 'ARTISAN.ItemType'}}</label>
                            <input
                                type="text"
                                value="{{selectedRecipe.type}}"
                                disabled
                            >
                        </div>

                        <div class="artisan-inspector__field">
                            <label>{{localize 'ARTISAN.Category'}}</label>
                            <input
                                type="text"
                                value="{{selectedRecipe.category}}"
                                placeholder="{{localize 'ARTISAN.CategoryPlaceholder'}}"
                                data-artisan-field="category"
                                data-recipe-id="{{selectedRecipe.id}}"
                            >
                        </div>

                        <div class="artisan-inspector__field">
                            <label>{{localize 'ARTISAN.ProfileProfession'}}</label>
                            <select
                                data-artisan-field="profile"
                                data-recipe-id="{{selectedRecipe.id}}"
                            >
                                {{#each professionOptions}}
                                    <option value="{{id}}" title="{{description}}">{{label}} — {{skill}}</option>
                                {{/each}}
                            </select>
                            <input type="hidden" value="{{selectedRecipe.profile}}" data-artisan-recipe-profession-current>
                        </div>

                        <div class="artisan-inspector__field">
                            <label>{{localize 'ARTISAN.ProfessionLevelRequired'}}</label>
                            <input
                                type="number"
                                value="{{selectedRecipe.professionLevel}}"
                                min="0"
                                max="5"
                                step="1"
                                data-artisan-field="professionLevel"
                                data-recipe-id="{{selectedRecipe.id}}"
                            >
                            <small>{{localize 'ARTISAN.RecipeRequirementHelp'}}</small>
                        </div>

                        <div class="artisan-inspector__field">
                            <label>{{localize 'ARTISAN.TimeMinutes'}}</label>
                            <input
                                type="number"
                                value="{{selectedRecipe.craftingTime}}"
                                min="0"
                                step="1"
                                data-artisan-field="craftingTime"
                                data-recipe-id="{{selectedRecipe.id}}"
                            >
                        </div>

                        <div class="artisan-inspector__field">
                            <label>{{localize 'ARTISAN.CraftingXp'}}</label>
                            <input
                                type="number"
                                value="{{selectedRecipe.craftingXp}}"
                                min="0"
                                step="1"
                                data-artisan-field="craftingXp"
                                data-recipe-id="{{selectedRecipe.id}}"
                            >
                            <small>{{localize 'ARTISAN.CraftingXpHelp'}}</small>
                        </div>

                        <div class="artisan-inspector__field">
                            <label>{{localize 'ARTISAN.CurrencyCost'}}</label>
                            <input
                                type="number"
                                value="{{selectedRecipe.currencyCost}}"
                                min="0"
                                step="0.01"
                                data-artisan-field="currencyCost"
                                data-recipe-id="{{selectedRecipe.id}}"
                            >
                            <small>{{localize 'ARTISAN.CurrencyCostHelp'}}</small>
                        </div>

                        <div class="artisan-inspector__field">
                            <label>{{localize 'ARTISAN.CurrencyDenomination'}}</label>
                            <select
                                data-artisan-field="currencyDenomination"
                                data-recipe-id="{{selectedRecipe.id}}"
                            >
                                <option value="cp" {{#if (eq selectedRecipe.currencyDenomination "cp")}}selected{{/if}}>{{localize 'ARTISAN.CurrencyCp'}}</option>
                                <option value="sp" {{#if (eq selectedRecipe.currencyDenomination "sp")}}selected{{/if}}>{{localize 'ARTISAN.CurrencySp'}}</option>
                                <option value="ep" {{#if (eq selectedRecipe.currencyDenomination "ep")}}selected{{/if}}>{{localize 'ARTISAN.CurrencyEp'}}</option>
                                <option value="gp" {{#if (eq selectedRecipe.currencyDenomination "gp")}}selected{{/if}}>{{localize 'ARTISAN.CurrencyGp'}}</option>
                                <option value="pp" {{#if (eq selectedRecipe.currencyDenomination "pp")}}selected{{/if}}>{{localize 'ARTISAN.CurrencyPp'}}</option>
                            </select>
                            <small>{{localize 'ARTISAN.CurrencyDenominationHelp'}}</small>
                        </div>

                        <div class="artisan-inspector__field artisan-toggle-field">
                            <label>{{localize 'ARTISAN.CurrencyOnFailure'}}</label>
                            <label class="artisan-checkbox-line">
                                <input type="checkbox" data-artisan-field="consumeCurrencyOnFailure" data-recipe-id="{{selectedRecipe.id}}" {{#if selectedRecipe.consumeCurrencyOnFailure}}checked{{/if}}>
                                <span>{{localize 'ARTISAN.CurrencyOnFailureCheckbox'}}</span>
                            </label>
                            <small>{{localize 'ARTISAN.CurrencyOnFailureHelp'}}</small>
                        </div>

                        <div class="artisan-inspector__field artisan-inspector__field--wide artisan-quality-compact">
                            <div class="artisan-quality-compact__header">
                                <label>{{localize 'ARTISAN.QualityEffectsTitle'}}</label>
                                <small>{{localize 'ARTISAN.QualityBonusHelp'}}</small>
                            </div>

                            <div class="artisan-quality-compact__formula">
                                <label>
                                    <span>{{localize 'ARTISAN.QualityFormulaPath'}}</span>
                                    <input
                                        type="text"
                                        value="{{selectedRecipe.qualityFormulaPath}}"
                                        placeholder="{{localize 'ARTISAN.QualityFormulaPathPlaceholder'}}"
                                        data-artisan-field="qualityFormulaPath"
                                        data-recipe-id="{{selectedRecipe.id}}"
                                    >
                                </label>
                                <small>{{localize 'ARTISAN.QualityFormulaPathHelp'}}</small>
                            </div>

                            <div class="artisan-quality-compact__table">
                                <div class="artisan-quality-compact__row artisan-quality-compact__row--head">
                                    <span>{{localize 'ARTISAN.QualityTier'}}</span>
                                    <span>{{localize 'ARTISAN.QualityFlatBonus'}}</span>
                                    <span>{{localize 'ARTISAN.QualityDice'}}</span>
                                    <span>{{localize 'ARTISAN.QualityEffectType'}}</span>
                                </div>
                            <div class="artisan-quality-compact__row">
                                <div class="artisan-quality-compact__tier">{{localize 'ARTISAN.QualityTierGood'}}</div>
                                <label class="artisan-quality-compact__cell">
                                    <span>{{localize 'ARTISAN.QualityFlatBonus'}}</span>
                                    <input
                                        type="number"
                                        value="{{selectedRecipe.qualityBonusGood}}"
                                        min="0"
                                        step="1"
                                        data-artisan-field="qualityBonusGood"
                                        data-recipe-id="{{selectedRecipe.id}}"
                                    >
                                </label>
                                <label class="artisan-quality-compact__cell">
                                    <span>{{localize 'ARTISAN.QualityDice'}}</span>
                                    <input
                                        type="text"
                                        value="{{selectedRecipe.qualityDiceGood}}"
                                        placeholder="1d4"
                                        data-artisan-field="qualityDiceGood"
                                        data-recipe-id="{{selectedRecipe.id}}"
                                    >
                                </label>
                                <label class="artisan-quality-compact__cell artisan-quality-compact__cell--effect">
                                    <span>{{localize 'ARTISAN.QualityEffectType'}}</span>
                                    <select
                                        data-artisan-field="qualityEffectGood"
                                        data-artisan-quality-effect-select
                                        data-current-effect="{{selectedRecipe.qualityEffectGood}}"
                                        data-recipe-id="{{selectedRecipe.id}}"
                                    >
                                        <option value="auto">{{localize 'ARTISAN.QualityEffectAuto'}}</option>
                                        <option value="healing">{{localize 'ARTISAN.QualityEffectHealing'}}</option>
                                        <option value="acid">{{localize 'ARTISAN.DamageAcid'}}</option>
                                        <option value="fire">{{localize 'ARTISAN.DamageFire'}}</option>
                                        <option value="poison">{{localize 'ARTISAN.DamagePoison'}}</option>
                                        <option value="cold">{{localize 'ARTISAN.DamageCold'}}</option>
                                        <option value="lightning">{{localize 'ARTISAN.DamageLightning'}}</option>
                                        <option value="thunder">{{localize 'ARTISAN.DamageThunder'}}</option>
                                        <option value="necrotic">{{localize 'ARTISAN.DamageNecrotic'}}</option>
                                        <option value="radiant">{{localize 'ARTISAN.DamageRadiant'}}</option>
                                        <option value="psychic">{{localize 'ARTISAN.DamagePsychic'}}</option>
                                        <option value="force">{{localize 'ARTISAN.DamageForce'}}</option>
                                        <option value="bludgeoning">{{localize 'ARTISAN.DamageBludgeoning'}}</option>
                                        <option value="piercing">{{localize 'ARTISAN.DamagePiercing'}}</option>
                                        <option value="slashing">{{localize 'ARTISAN.DamageSlashing'}}</option>
                                    </select>
                                </label>
                            </div>
                            <div class="artisan-quality-compact__row">
                                <div class="artisan-quality-compact__tier">{{localize 'ARTISAN.QualityTierSuperior'}}</div>
                                <label class="artisan-quality-compact__cell">
                                    <span>{{localize 'ARTISAN.QualityFlatBonus'}}</span>
                                    <input
                                        type="number"
                                        value="{{selectedRecipe.qualityBonusSuperior}}"
                                        min="0"
                                        step="1"
                                        data-artisan-field="qualityBonusSuperior"
                                        data-recipe-id="{{selectedRecipe.id}}"
                                    >
                                </label>
                                <label class="artisan-quality-compact__cell">
                                    <span>{{localize 'ARTISAN.QualityDice'}}</span>
                                    <input
                                        type="text"
                                        value="{{selectedRecipe.qualityDiceSuperior}}"
                                        placeholder="1d4"
                                        data-artisan-field="qualityDiceSuperior"
                                        data-recipe-id="{{selectedRecipe.id}}"
                                    >
                                </label>
                                <label class="artisan-quality-compact__cell artisan-quality-compact__cell--effect">
                                    <span>{{localize 'ARTISAN.QualityEffectType'}}</span>
                                    <select
                                        data-artisan-field="qualityEffectSuperior"
                                        data-artisan-quality-effect-select
                                        data-current-effect="{{selectedRecipe.qualityEffectSuperior}}"
                                        data-recipe-id="{{selectedRecipe.id}}"
                                    >
                                        <option value="auto">{{localize 'ARTISAN.QualityEffectAuto'}}</option>
                                        <option value="healing">{{localize 'ARTISAN.QualityEffectHealing'}}</option>
                                        <option value="acid">{{localize 'ARTISAN.DamageAcid'}}</option>
                                        <option value="fire">{{localize 'ARTISAN.DamageFire'}}</option>
                                        <option value="poison">{{localize 'ARTISAN.DamagePoison'}}</option>
                                        <option value="cold">{{localize 'ARTISAN.DamageCold'}}</option>
                                        <option value="lightning">{{localize 'ARTISAN.DamageLightning'}}</option>
                                        <option value="thunder">{{localize 'ARTISAN.DamageThunder'}}</option>
                                        <option value="necrotic">{{localize 'ARTISAN.DamageNecrotic'}}</option>
                                        <option value="radiant">{{localize 'ARTISAN.DamageRadiant'}}</option>
                                        <option value="psychic">{{localize 'ARTISAN.DamagePsychic'}}</option>
                                        <option value="force">{{localize 'ARTISAN.DamageForce'}}</option>
                                        <option value="bludgeoning">{{localize 'ARTISAN.DamageBludgeoning'}}</option>
                                        <option value="piercing">{{localize 'ARTISAN.DamagePiercing'}}</option>
                                        <option value="slashing">{{localize 'ARTISAN.DamageSlashing'}}</option>
                                    </select>
                                </label>
                            </div>
                            <div class="artisan-quality-compact__row">
                                <div class="artisan-quality-compact__tier">{{localize 'ARTISAN.QualityTierExcellent'}}</div>
                                <label class="artisan-quality-compact__cell">
                                    <span>{{localize 'ARTISAN.QualityFlatBonus'}}</span>
                                    <input
                                        type="number"
                                        value="{{selectedRecipe.qualityBonusExcellent}}"
                                        min="0"
                                        step="1"
                                        data-artisan-field="qualityBonusExcellent"
                                        data-recipe-id="{{selectedRecipe.id}}"
                                    >
                                </label>
                                <label class="artisan-quality-compact__cell">
                                    <span>{{localize 'ARTISAN.QualityDice'}}</span>
                                    <input
                                        type="text"
                                        value="{{selectedRecipe.qualityDiceExcellent}}"
                                        placeholder="1d4"
                                        data-artisan-field="qualityDiceExcellent"
                                        data-recipe-id="{{selectedRecipe.id}}"
                                    >
                                </label>
                                <label class="artisan-quality-compact__cell artisan-quality-compact__cell--effect">
                                    <span>{{localize 'ARTISAN.QualityEffectType'}}</span>
                                    <select
                                        data-artisan-field="qualityEffectExcellent"
                                        data-artisan-quality-effect-select
                                        data-current-effect="{{selectedRecipe.qualityEffectExcellent}}"
                                        data-recipe-id="{{selectedRecipe.id}}"
                                    >
                                        <option value="auto">{{localize 'ARTISAN.QualityEffectAuto'}}</option>
                                        <option value="healing">{{localize 'ARTISAN.QualityEffectHealing'}}</option>
                                        <option value="acid">{{localize 'ARTISAN.DamageAcid'}}</option>
                                        <option value="fire">{{localize 'ARTISAN.DamageFire'}}</option>
                                        <option value="poison">{{localize 'ARTISAN.DamagePoison'}}</option>
                                        <option value="cold">{{localize 'ARTISAN.DamageCold'}}</option>
                                        <option value="lightning">{{localize 'ARTISAN.DamageLightning'}}</option>
                                        <option value="thunder">{{localize 'ARTISAN.DamageThunder'}}</option>
                                        <option value="necrotic">{{localize 'ARTISAN.DamageNecrotic'}}</option>
                                        <option value="radiant">{{localize 'ARTISAN.DamageRadiant'}}</option>
                                        <option value="psychic">{{localize 'ARTISAN.DamagePsychic'}}</option>
                                        <option value="force">{{localize 'ARTISAN.DamageForce'}}</option>
                                        <option value="bludgeoning">{{localize 'ARTISAN.DamageBludgeoning'}}</option>
                                        <option value="piercing">{{localize 'ARTISAN.DamagePiercing'}}</option>
                                        <option value="slashing">{{localize 'ARTISAN.DamageSlashing'}}</option>
                                    </select>
                                </label>
