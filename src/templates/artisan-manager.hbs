<div class="artisan-manager__layout">

    <aside class="artisan-manager__sidebar">

        <div class="artisan-manager__brand">
            <h2>{{title}}</h2>
            <p>{{subtitle}}</p>
        </div>

        <nav class="artisan-explorer">
            {{#each explorer}}
                <section class="artisan-explorer__section" data-section="{{id}}">

                    <button
                        type="button"
                        class="artisan-explorer__section-header artisan-explorer__section-button {{#if (eq ../selectedSectionId id)}}is-selected{{/if}}"
                        data-artisan-select-section
                        data-section-id="{{id}}"
                    >
                        <span>
                            <i class="{{icon}}"></i>
                            {{label}}
                        </span>

                        <span class="artisan-explorer__count">{{count}}</span>
                    </button>

                    <div class="artisan-explorer__items">
                        {{#if items.length}}
                            {{#each items}}
                                <button
                                    type="button"
                                    class="artisan-explorer__item {{#if selected}}is-selected{{/if}} {{recipeStatusClass}}"
                                    title="{{recipeStatusTitle}}"
                                    data-artisan-select-recipe
                                    data-recipe-id="{{id}}"
                                >
                                    <span class="artisan-explorer__item-main">
                                        {{#if icon}}<i class="{{icon}}"></i>{{/if}}
                                        <span>{{label}}</span>
                                    </span>
                                    {{#if recipeStatusLabel}}
                                        <span class="artisan-recipe-status-badge {{recipeStatusClass}}">
                                            <i class="{{recipeStatusIcon}}"></i>
                                            {{recipeStatusLabel}}
                                        </span>
                                    {{/if}}
                                </button>
                            {{/each}}
                        {{else}}
                            <p class="artisan-explorer__empty">Nessun elemento</p>
                        {{/if}}
                    </div>

                </section>
            {{/each}}
        </nav>

    </aside>

    <main class="artisan-manager__content">

        {{#if isRecipesSection}}

            <header class="artisan-manager__toolbar">
                <h3>Ricette</h3>

                <div class="artisan-toolbar-actions">
                    <button type="button" class="artisan-button" data-artisan-new-recipe>
                        <i class="fa-solid fa-plus"></i>
                        Nuova Ricetta
                    </button>

                    <button type="button" class="artisan-button" data-artisan-import-recipes>
                        <i class="fa-solid fa-file-import"></i>
                        Importa ricette
                    </button>

                    <button type="button" class="artisan-button" data-artisan-export-all-recipes>
                        <i class="fa-solid fa-file-export"></i>
                        Esporta tutte
                    </button>

                    <button type="button" class="artisan-button" data-artisan-export-backup>
                        <i class="fa-solid fa-download"></i>
                        Backup Artisan
                    </button>

                    <button type="button" class="artisan-button" data-artisan-import-backup>
                        <i class="fa-solid fa-upload"></i>
                        Ripristina backup
                    </button>
                </div>

                <input
                    type="file"
                    accept="application/json,.json"
                    class="artisan-hidden-file-input"
                    data-artisan-import-recipes-file
                >

                <input
                    type="file"
                    accept="application/json,.json"
                    class="artisan-hidden-file-input"
                    data-artisan-import-backup-file
                >
            </header>

            <section class="artisan-filter-panel">
                <div class="artisan-filter-panel__header">
                    <strong>Ricerca e filtri ricette</strong>
                    <span>{{recipeCountFiltered}} / {{recipeCountTotal}}</span>
                </div>

                <div class="artisan-filter-panel__grid">
                    <label>
                        <span>Nome / categoria</span>
                        <input
                            type="search"
                            value="{{recipeFilters.search}}"
                            placeholder="Cerca ricetta..."
                            data-artisan-recipe-filter
                            data-filter="search"
                        >
                    </label>

                    <label>
                        <span>Professione</span>
                        <select data-artisan-recipe-filter data-filter="profession">
                            <option value="all">Tutte</option>
                            {{#each recipeFilterProfessionOptions}}
                                <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                            {{/each}}
                        </select>
                    </label>

                    <label>
                        <span>Categoria</span>
                        <select data-artisan-recipe-filter data-filter="category">
                            <option value="all">Tutte</option>
                            {{#each recipeFilterCategoryOptions}}
                                <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                            {{/each}}
                        </select>
                    </label>

                    <label>
                        <span>Livello richiesto</span>
                        <select data-artisan-recipe-filter data-filter="level">
                            <option value="all">Tutti</option>
                            {{#each recipeFilterLevelOptions}}
                                <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                            {{/each}}
                        </select>
                    </label>

                    <button type="button" class="artisan-small-button" data-artisan-reset-recipe-filters>
                        <i class="fa-solid fa-filter-circle-xmark"></i>
                        Pulisci filtri
                    </button>
                </div>
            </section>

            {{#if selectedRecipe}}

                <section class="artisan-inspector">

                    <header class="artisan-inspector__header">

                        <div class="artisan-inspector__header-main">
                            <img src="{{selectedRecipe.img}}" alt="{{selectedRecipe.name}}">
                            <div>
                                <h2>{{selectedRecipe.name}}</h2>
                                <p>{{selectedRecipe.uuid}}</p>
                            </div>
                        </div>

                        <div class="artisan-inspector__header-actions">
                            <button
                                type="button"
                                class="artisan-small-button {{#if selectedRecipe.recipeLocked}}is-disabled{{/if}}"
                                {{#if selectedRecipe.recipeLocked}}disabled{{/if}}
                                data-artisan-roll-crafting
                                data-recipe-id="{{selectedRecipe.id}}"
                            >
                                <i class="fa-solid fa-dice-d20"></i>
                                Esegui Crafting
                            </button>

                            <button
                                type="button"
                                class="artisan-small-button"
                                data-artisan-preview-crafting
                                data-recipe-id="{{selectedRecipe.id}}"
                            >
                                <i class="fa-solid fa-eye"></i>
                                Anteprima
                            </button>

                            <button
                                type="button"
                                class="artisan-small-button"
                                data-artisan-validate-recipe
                                data-recipe-id="{{selectedRecipe.id}}"
                            >
                                <i class="fa-solid fa-check"></i>
                                Verifica
                            </button>

                            <button
                                type="button"
                                class="artisan-small-button"
                                data-artisan-export-recipe
                                data-recipe-id="{{selectedRecipe.id}}"
                            >
                                <i class="fa-solid fa-file-export"></i>
                                Esporta ricetta
                            </button>

                            <button
                                type="button"
                                class="artisan-small-button"
                                data-artisan-duplicate-recipe
                                data-recipe-id="{{selectedRecipe.id}}"
                            >
                                <i class="fa-solid fa-copy"></i>
                                Duplica ricetta
                            </button>
                        </div>

                    </header>

                    <section class="artisan-recipe-requirement-card {{selectedRecipe.recipeStatusClass}}">
                        <div>
                            <strong>Disponibilità per il PG selezionato</strong>
                            <p>{{selectedRecipe.recipeStatusTitle}}</p>
                        </div>
                        <span class="artisan-recipe-status-badge {{selectedRecipe.recipeStatusClass}}">
                            <i class="{{selectedRecipe.recipeStatusIcon}}"></i>
                            {{selectedRecipe.recipeStatusLabel}}
                        </span>
                    </section>

                    <div class="artisan-inspector__form">

                        <div class="artisan-inspector__field">
                            <label>Nome ricetta</label>
                            <input
                                type="text"
                                value="{{selectedRecipe.name}}"
                                data-artisan-field="name"
                                data-recipe-id="{{selectedRecipe.id}}"
                            >
                        </div>

                        <div class="artisan-inspector__field">
                            <label>Tipo Item</label>
                            <input
                                type="text"
                                value="{{selectedRecipe.type}}"
                                disabled
                            >
                        </div>

                        <div class="artisan-inspector__field">
                            <label>Categoria</label>
                            <input
                                type="text"
                                value="{{selectedRecipe.category}}"
                                placeholder="Es. Alchimia, Cucina, Forgiatura"
                                data-artisan-field="category"
                                data-recipe-id="{{selectedRecipe.id}}"
                            >
                        </div>

                        <div class="artisan-inspector__field">
                            <label>Profilo / Professione</label>
                            <select
                                data-artisan-field="profile"
                                data-recipe-id="{{selectedRecipe.id}}"
                            >
                                {{#each professionOptions}}
                                    <option value="{{id}}" title="{{description}}">{{label}} — {{skill}}</option>
                                {{/each}}
                            </select>
                            <input type="hidden" value="{{selectedRecipe.profile}}" data-artisan-recipe-profession-current>
                        </div>

                        <div class="artisan-inspector__field">
                            <label>Livello professione richiesto</label>
                            <input
                                type="number"
                                value="{{selectedRecipe.professionLevel}}"
                                min="0"
                                max="5"
                                step="1"
                                data-artisan-field="professionLevel"
                                data-recipe-id="{{selectedRecipe.id}}"
                            >
                            <small>Requisito della ricetta: il PG deve avere almeno questo livello nella professione selezionata.</small>
                        </div>

                        <div class="artisan-inspector__field">
                            <label>Tempo (minuti)</label>
                            <input
                                type="number"
                                value="{{selectedRecipe.craftingTime}}"
                                min="0"
                                step="1"
                                data-artisan-field="craftingTime"
                                data-recipe-id="{{selectedRecipe.id}}"
                            >
                        </div>

                        <div class="artisan-inspector__field">
                            <label>Abilità</label>
                            <input
                                type="text"
                                value="{{selectedRecipe.skill}}"
                                placeholder="Es. survival, arcana, nature"
                                data-artisan-field="skill"
                                data-recipe-id="{{selectedRecipe.id}}"
                            >
                        </div>

                        <div class="artisan-inspector__field">
                            <label>CD</label>
                            <input
                                type="number"
                                value="{{selectedRecipe.dc}}"
                                min="0"
                                step="1"
                                data-artisan-field="dc"
                                data-recipe-id="{{selectedRecipe.id}}"
                            >
                        </div>

                    </div>

                    <section
                        class="artisan-component-panel"
                        data-artisan-drop-zone
                        data-recipe-id="{{selectedRecipe.id}}"
                        data-collection="ingredients"
                    >

                        <header class="artisan-component-panel__header">
                            <h3>Ingredienti</h3>
                            <span>Trascina qui un Item o usa UUID manuale</span>
                        </header>

                        <div class="artisan-component-add">
                            <input type="text" placeholder="UUID Item o Compendium" data-artisan-component-uuid>
                            <input type="number" min="1" step="1" value="1" data-artisan-component-quantity>
                            <button type="button" class="artisan-small-button" data-artisan-add-component data-recipe-id="{{selectedRecipe.id}}" data-collection="ingredients">
                                <i class="fa-solid fa-plus"></i>
                                Aggiungi
                            </button>
                        </div>

                        {{#if selectedRecipe.ingredients.length}}
                            <div class="artisan-component-list">
                                {{#each selectedRecipe.ingredients}}
                                    <div class="artisan-component-row {{#unless found}}is-missing{{/unless}}">
                                        <img src="{{img}}" alt="{{name}}">
                                        <button type="button" class="artisan-component-row__main" data-artisan-open-component data-uuid="{{uuid}}" title="Apri Item">
                                            <strong>{{name}}</strong>
                                            <code>{{uuid}}</code>
                                        </button>
                                        <input type="number" min="1" step="1" value="{{quantity}}" class="artisan-component-row__quantity" data-artisan-component-row-quantity data-recipe-id="{{recipeId}}" data-collection="{{collection}}" data-index="{{index}}">
                                        <button type="button" class="artisan-icon-button" data-artisan-open-component data-uuid="{{uuid}}" title="Apri">
                                            <i class="fa-solid fa-up-right-from-square"></i>
                                        </button>
                                        <button type="button" class="artisan-icon-button" data-artisan-remove-component data-recipe-id="{{recipeId}}" data-collection="{{collection}}" data-index="{{index}}" title="Rimuovi">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    </div>
                                {{/each}}
                            </div>
                        {{else}}
                            <p class="artisan-component-panel__empty">Nessun ingrediente inserito.</p>
                        {{/if}}

                    </section>

                    <section class="artisan-component-panel" data-artisan-drop-zone data-recipe-id="{{selectedRecipe.id}}" data-collection="tools">
                        <header class="artisan-component-panel__header">
                            <h3>Strumenti richiesti</h3>
                            <span>Trascina qui un Item o usa UUID manuale</span>
                        </header>

                        <div class="artisan-component-add">
                            <input type="text" placeholder="UUID Item o Compendium" data-artisan-component-uuid>
                            <input type="number" min="1" step="1" value="1" data-artisan-component-quantity>
                            <button type="button" class="artisan-small-button" data-artisan-add-component data-recipe-id="{{selectedRecipe.id}}" data-collection="tools">
                                <i class="fa-solid fa-plus"></i>
                                Aggiungi
                            </button>
                        </div>

                        {{#if selectedRecipe.tools.length}}
                            <div class="artisan-component-list">
                                {{#each selectedRecipe.tools}}
                                    <div class="artisan-component-row {{#unless found}}is-missing{{/unless}}">
                                        <img src="{{img}}" alt="{{name}}">
                                        <button type="button" class="artisan-component-row__main" data-artisan-open-component data-uuid="{{uuid}}" title="Apri Item">
                                            <strong>{{name}}</strong>
                                            <code>{{uuid}}</code>
                                        </button>
                                        <input type="number" min="1" step="1" value="{{quantity}}" class="artisan-component-row__quantity" data-artisan-component-row-quantity data-recipe-id="{{recipeId}}" data-collection="{{collection}}" data-index="{{index}}">
                                        <button type="button" class="artisan-icon-button" data-artisan-open-component data-uuid="{{uuid}}" title="Apri">
                                            <i class="fa-solid fa-up-right-from-square"></i>
                                        </button>
                                        <button type="button" class="artisan-icon-button" data-artisan-remove-component data-recipe-id="{{recipeId}}" data-collection="{{collection}}" data-index="{{index}}" title="Rimuovi">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    </div>
                                {{/each}}
                            </div>
                        {{else}}
                            <p class="artisan-component-panel__empty">Nessuno strumento richiesto.</p>
                        {{/if}}
                    </section>

                    <section class="artisan-component-panel" data-artisan-drop-zone data-recipe-id="{{selectedRecipe.id}}" data-collection="outputs">
                        <header class="artisan-component-panel__header">
                            <h3>Output</h3>
                            <span>Trascina qui un Item o usa UUID manuale</span>
                        </header>

                        <div class="artisan-component-add">
                            <input type="text" placeholder="UUID Item o Compendium" data-artisan-component-uuid>
                            <input type="number" min="1" step="1" value="1" data-artisan-component-quantity>
                            <button type="button" class="artisan-small-button" data-artisan-add-component data-recipe-id="{{selectedRecipe.id}}" data-collection="outputs">
                                <i class="fa-solid fa-plus"></i>
                                Aggiungi
                            </button>
                        </div>

                        {{#if selectedRecipe.outputs.length}}
                            <div class="artisan-component-list">
                                {{#each selectedRecipe.outputs}}
                                    <div class="artisan-component-row {{#unless found}}is-missing{{/unless}}">
                                        <img src="{{img}}" alt="{{name}}">
                                        <button type="button" class="artisan-component-row__main" data-artisan-open-component data-uuid="{{uuid}}" title="Apri Item">
                                            <strong>{{name}}</strong>
                                            <code>{{uuid}}</code>
                                        </button>
                                        <input type="number" min="1" step="1" value="{{quantity}}" class="artisan-component-row__quantity" data-artisan-component-row-quantity data-recipe-id="{{recipeId}}" data-collection="{{collection}}" data-index="{{index}}">
                                        <button type="button" class="artisan-icon-button" data-artisan-open-component data-uuid="{{uuid}}" title="Apri">
                                            <i class="fa-solid fa-up-right-from-square"></i>
                                        </button>
                                        <button type="button" class="artisan-icon-button" data-artisan-remove-component data-recipe-id="{{recipeId}}" data-collection="{{collection}}" data-index="{{index}}" title="Rimuovi">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    </div>
                                {{/each}}
                            </div>
                        {{else}}
                            <p class="artisan-component-panel__empty">Nessun output inserito.</p>
                        {{/if}}
                    </section>

                    <section class="artisan-inspector__summary">
                        <div><strong>{{selectedRecipe.ingredientCount}}</strong><span>Ingredienti</span></div>
                        <div><strong>{{selectedRecipe.toolCount}}</strong><span>Strumenti</span></div>
                        <div><strong>{{selectedRecipe.outputCount}}</strong><span>Output</span></div>
                    </section>

                </section>

            {{else}}

                <section class="artisan-manager__empty">
                    <i class="fa-solid fa-hammer"></i>
                    <h3>Nessuna ricetta selezionata</h3>
                    <p>Crea una nuova ricetta o selezionane una dall’elenco.</p>
                </section>

            {{/if}}

        {{/if}}

        {{#if isForagingSection}}

            <header class="artisan-manager__toolbar">
                <h3>Foraging</h3>

                <div class="artisan-toolbar-actions">
                    <button type="button" class="artisan-small-button" data-artisan-export-foraging>
                        <i class="fa-solid fa-file-export"></i>
                        Esporta liste
                    </button>

                    <button type="button" class="artisan-small-button" data-artisan-import-foraging>
                        <i class="fa-solid fa-file-import"></i>
                        Importa liste
                    </button>

                    <input type="file" accept="application/json,.json" data-artisan-import-foraging-file hidden>

                    <button type="button" class="artisan-button" data-artisan-new-foraging-profile>
                        <i class="fa-solid fa-plus"></i>
                        Nuova lista
                    </button>
                </div>
            </header>

            <section class="artisan-foraging-layout">

                <aside class="artisan-foraging-list">
                    {{#if foragingProfiles.length}}
                        {{#each foragingProfiles}}
                            <button
                                type="button"
                                class="artisan-explorer__item {{#if selected}}is-selected{{/if}}"
                                data-artisan-select-foraging-profile
                                data-profile-id="{{id}}"
                            >
                                <i class="{{icon}}"></i>
                                <span>{{label}}</span>
                            </button>
                        {{/each}}
                    {{else}}
                        <p class="artisan-component-panel__empty">Nessuna lista Foraging.</p>
                    {{/if}}
                </aside>

                <main class="artisan-foraging-content">
                    {{#if selectedForagingProfile}}

                        <header class="artisan-inspector__header">
                            <div class="artisan-inspector__header-main">
                                <i class="fa-solid fa-leaf artisan-foraging-icon"></i>
                                <div>
                                    <h2>{{selectedForagingProfile.name}}</h2>
                                    <p>{{selectedForagingProfile.id}}</p>
                                </div>
                            </div>

                            <div class="artisan-inspector__header-actions">
                                <button
                                    type="button"
                                    class="artisan-button"
                                    data-artisan-start-foraging
                                    data-profile-id="{{selectedForagingProfile.id}}"
                                >
                                    <i class="fa-solid fa-dice-d20"></i>
                                    Avvia Foraging
                                </button>

                                <button
                                    type="button"
                                    class="artisan-small-button artisan-danger-button"
                                    data-artisan-delete-foraging-profile
                                    data-profile-id="{{selectedForagingProfile.id}}"
                                >
                                    <i class="fa-solid fa-trash"></i>
                                    Cancella lista
                                </button>
                            </div>
                        </header>

                        <div class="artisan-inspector__form">
                            <div class="artisan-inspector__field">
                                <label>Nome lista</label>
                                <input type="text" value="{{selectedForagingProfile.name}}" data-artisan-foraging-field="name" data-profile-id="{{selectedForagingProfile.id}}">
                            </div>

                            <div class="artisan-inspector__field">
                                <label>Bioma</label>
                                <select data-artisan-foraging-field="biome" data-profile-id="{{selectedForagingProfile.id}}">
                                    <option value="foresta">Foresta</option>
                                    <option value="montagna">Montagna</option>
                                    <option value="palude">Palude</option>
                                    <option value="costa">Costa</option>
                                    <option value="caverna">Caverna</option>
                                    <option value="deserto">Deserto</option>
                                    <option value="artico">Artico</option>
                                    <option value="urbano">Urbano</option>
                                    <option value="pianura">Pianura</option>
                                    <option value="collina">Collina</option>
                                    <option value="fiume">Fiume / Lago</option>
                                </select>
                                <input type="hidden" value="{{selectedForagingProfile.biome}}" data-artisan-foraging-biome-current>
                            </div>

                            <div class="artisan-inspector__field">
                                <label>Professione</label>
                                <select data-artisan-foraging-field="profession" data-profile-id="{{selectedForagingProfile.id}}">
                                    {{#each foragingProfessionOptions}}
                                        <option value="{{id}}" title="{{description}}">{{label}} — {{skill}}</option>
                                    {{/each}}
                                </select>
                                <input type="hidden" value="{{selectedForagingProfile.profession}}" data-artisan-foraging-profession-current>
                            </div>

                            <div class="artisan-inspector__field">
                                <label>Professione del PG</label>
                                {{#if selectedForagingActorProfession}}
                                    <input type="text" value="{{selectedForagingActorName}} — livello {{selectedForagingActorProfession.level}}, XP {{selectedForagingActorProfession.xp}}, prossimo livello: {{selectedForagingActorProfession.xpToNextLevel}} XP, raccolta {{selectedForagingActorProfession.gatheringMultiplierLabel}}" disabled>
                                    <small>Il livello viene letto dal PG selezionato. La lista Foraging non salva più un livello manuale.</small>
                                {{else}}
                                    <input type="text" value="Seleziona un token per leggere la professione dal PG" disabled>
                                {{/if}}
                            </div>

                            <div class="artisan-inspector__field">
                                <label>Abilità tiro</label>
                                <input type="text" value="{{selectedForagingProfile.skill}}" placeholder="Es. survival, nature, perception" data-artisan-foraging-field="skill" data-profile-id="{{selectedForagingProfile.id}}">
                            </div>

                            <div class="artisan-inspector__field">
                                <label>CD</label>
                                <input type="number" value="{{selectedForagingProfile.dc}}" min="0" step="1" data-artisan-foraging-field="dc" data-profile-id="{{selectedForagingProfile.id}}">
                            </div>

                            <div class="artisan-inspector__field">
                                <label>Tempo (minuti)</label>
                                <input type="number" value="{{selectedForagingProfile.time}}" min="0" step="1" data-artisan-foraging-field="time" data-profile-id="{{selectedForagingProfile.id}}">
                            </div>

                            <div class="artisan-inspector__field">
                                <label>Massimo risorse diverse</label>
                                <input type="number" value="{{selectedForagingProfile.maxResources}}" min="1" step="1" data-artisan-foraging-field="maxResources" data-profile-id="{{selectedForagingProfile.id}}">
                                <small>Limita quante risorse diverse possono uscire da una singola raccolta.</small>
                            </div>
                        </div>

                        <section class="artisan-foraging-panel" data-artisan-foraging-drop-zone data-profile-id="{{selectedForagingProfile.id}}" data-collection="resources">
                            <header class="artisan-component-panel__header">
                                <h3>Risorse raccoglibili</h3>
                                <span>Trascina Item da compendio o mondo</span>
                            </header>

                            <div class="artisan-component-add artisan-foraging-resource-add">
                                <input type="text" placeholder="UUID risorsa" data-artisan-foraging-component-uuid>
                                <input type="number" min="0.1" step="0.1" title="Peso importato dall'Item, modificabile" placeholder="Peso auto" data-artisan-foraging-component-weight>
                                <input type="number" min="1" step="1" value="1" title="Quantità minima" placeholder="Min" data-artisan-foraging-component-min-quantity>
                                <input type="number" min="1" step="1" value="1" title="Quantità massima" placeholder="Max" data-artisan-foraging-component-max-quantity>
